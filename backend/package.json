{
  "name": "sop10-trader-backend",
  "version": "1.0.0",
  "description": "SOP10 Trader App Backend - Express + PostgreSQL + TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "dev": "npm run build && node --experimental-specifier-resolution=node dist/server.js",
    "build": "tsc",
    "start": "node dist/server.js",
