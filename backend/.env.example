# Database
DATABASE_URL=postgresql://trader:tradersecret@localhost:5432/sop10_trader

# Database Connection Pool (Phase 8 Optimization)
DB_POOL_MAX=20                    # Maximum concurrent connections (default: 20)
DB_POOL_MIN=2                     # Minimum connections to maintain (default: 2)
DB_IDLE_TIMEOUT=30000             # Milliseconds before closing idle connection (default: 30000)
DB_CONNECTION_TIMEOUT=2000        # Milliseconds to acquire a connection (default: 2000)

# Environment
NODE_ENV=development
PORT=5000

# Logging
LOG_LEVEL=info                    # Levels: error, warn, info, debug, verbose

# Error Tracking & Monitoring
SENTRY_DSN=https://key@org.ingest.sentry.io/projectId

# FlashAlpha API (GEX + Greeks)
FLASHALPHA_API_KEY=your_api_key_here
FLASHALPHA_BASE_URL=https://lab.flashalpha.com/api/v1
